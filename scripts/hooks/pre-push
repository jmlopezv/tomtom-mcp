#!/bin/bash
#
# Pre-push hook: Regenerates tomtom-mcp.mcpb before pushing
#
# Note: The .mcpb file contains platform-specific native modules.
# It will only work on the same OS/architecture where it was built.
#

echo "Pre-push: Building tomtom-mcp.mcpb..."

# Build the project first (in case there are uncommitted dist changes)
npm run build --silent 2>/dev/null

# Generate the mcpb file
npm run build:mcpb

# Stage the mcpb file if it changed
if git diff --quiet tomtom-mcp.mcpb 2>/dev/null; then
  echo "  ✓ tomtom-mcp.mcpb is up to date"
else
  echo "  ⚠ tomtom-mcp.mcpb was updated - please commit and push again"
  git add tomtom-mcp.mcpb
  exit 1
fi
